{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "chrome": "writable",
    "browser": "writable",
    "importScripts": "readonly",
    "SS": "readonly",
    "SSExtract": "readonly",
    "SSSpecHeuristic": "readonly",
    "SSCanonical": "readonly",
    "SSProductRepo": "readonly",
    "SSDB": "readonly",
    "SSViewsRepo": "readonly",
    "ShopScoutUI": "readonly",
    "ShopScoutSanitize": "readonly",
    "ShopScoutAI": "readonly",
    "ShopScoutAIUI": "readonly",
    "ShopScoutAIDevMonitor": "readonly",
    "ShopScoutComparison": "readonly",
    "ShopScoutState": "readonly",
    "ShopScoutValues": "readonly",
    "ShopScoutProjections": "readonly",
    "ShopScoutEdits": "readonly",
    "ShopScoutGrid": "readonly",
    "ShopScoutGridState": "readonly",
    "ShopScoutGridProjections": "readonly",
    "ShopScoutGridRenderer": "readonly",
    "ShopScoutGridFormatters": "readonly",
    "ShopScoutGridColumnDefs": "readonly",
    "ShopScoutGridEdits": "readonly",
    "Slick": "readonly",
    "Dexie": "readonly",
    "openFeedbackPage": "readonly",
    "handleFeedbackAction": "readonly",
    "renderAiResultsPage": "readonly",
    "showAiResultsPage": "readonly",
    "buildRunProductList": "readonly",
    "isAiRunIncomplete": "readonly",
    "aiStageLabel": "readonly",
    "closeSettingsPage": "readonly",
    "getCorrectedValue": "readonly",
    "stageStatusText": "readonly",
    "renderAll": "readonly",
    "detailIndex": "writable",
    "rescanSingle": "readonly",
    "rescanList": "readonly",
    "rescanSelectedProducts": "readonly",
    "getSelectedProductIndexes": "readonly",
    "normalizeReviewCount": "readonly",
    "openEditModal": "readonly",
    "closeProductDetail": "readonly",
    "openProductDetail": "readonly",
    "saveEdit": "readonly",
    "switchEditTab": "readonly",
    "addSpecRow": "readonly",
    "updateImagePreview": "readonly",
    "renderCorrectedField": "readonly",
    "renderCorrectedSpecValue": "readonly",
    "editIndex": "writable"
  },
  "ignorePatterns": [
    "dist/**",
    "vendor/**",
    "node_modules/**",
    "archived/**",
    "grid-rebuild-codex/**"
  ],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-redeclare": "warn",
    "no-implicit-globals": "off",
    "no-async-promise-executor": "error",
    "no-await-in-loop": "off",
    "no-console": "off",
    "no-debugger": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-prototype-builtins": "off",
    "no-useless-escape": "warn",
    "no-fallthrough": "error"
  }
}
